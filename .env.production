# ===========================================
# FishCloud Production Environment
# Copy to .env and fill in real values
# ===========================================

# Domain (used by Caddy for auto-SSL)
DOMAIN=fishcloud.example.com

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# App secrets
SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=https://fishcloud.example.com/billing?success=1
STRIPE_CANCEL_URL=https://fishcloud.example.com/billing?cancel=1

# MiroFish engine (for self-hosted vLLM on spot GPUs)
# LLM_API_KEY is not needed for self-hosted vLLM — set to any value
LLM_API_KEY=not-needed-for-self-hosted
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=Qwen2.5-32B-Instruct-AWQ
ZEP_API_KEY=your_zep_cloud_api_key

# GPU providers
RUNPOD_API_KEY=your_runpod_api_key
VASTAI_API_KEY=your_vastai_api_key

# Redis (internal, no need to change)
REDIS_URL=redis://redis:6379/0
