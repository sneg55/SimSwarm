# --- Core ---
DATABASE_URL=postgresql+asyncpg://fishcloud:fishcloud@localhost:5432/fishcloud
SECRET_KEY=change-me-in-production
POSTGRES_PASSWORD=change-me            # used by docker-compose

# --- Read-only demo posture (leave false for a full self-hosted instance) ---
DEMO_MODE=false

# --- On-pod fast LLM (vLLM) ---
LLM_API_KEY=not-needed
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=Qwen/Qwen3-14B

# --- Neo4j graph DB (required) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- Report generation (Anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_key
SMART_MODEL=claude-opus-4-6

# --- GPU provider ---
RUNPOD_API_KEY=your_runpod_key         # read via os.getenv (not Settings); needed by worker

# --- MinIO object storage (sim artifacts) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_key
MINIO_SECRET_KEY=your_minio_secret
MINIO_BUCKET=simswarm
MINIO_SECURE=true
MINIO_PROXY_BASE=

# --- Temporal workflow engine ---
TEMPORAL_ADDRESS=temporal:7233         # read via os.getenv (default: temporal:7233)
TEMPORAL_NAMESPACE=fishcloud           # read via os.getenv (default: fishcloud)
TEMPORAL_DB_PASSWORD=change-me        # used by docker-compose temporal service

# --- Optional ---
XAI_API_KEY=                           # seed enrichment (web + X search)
OPENAI_API_KEY=                        # embeddings fallback
ALERT_WEBHOOK_URL=
LOG_FORMAT=json
WORKER_IMAGE_TAG=latest
WORKER_IMAGE_REPO=ghcr.io/sneg55/simswarm-worker
