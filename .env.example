# SaaS layer
DATABASE_URL=postgresql+asyncpg://fishcloud:fishcloud@localhost:5432/fishcloud
SECRET_KEY=change-me-in-production

# MiroFish engine (injected into adapter)
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=Qwen2.5-32B-Instruct-AWQ
ZEP_API_KEY=your_zep_api_key

# Logging
LOG_FORMAT=json

# Worker image tag (set automatically by CI/CD to git short SHA)
WORKER_IMAGE_TAG=latest
