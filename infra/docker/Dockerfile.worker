# GPU Worker Image for FishCloud
# Based on vLLM's official image (has CUDA + vLLM pre-installed)
FROM vllm/vllm-openai:v0.6.6.post1 AS base

USER root

# Install additional system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Save vLLM's pinned dependency versions before installing MiroFish deps
RUN pip freeze | grep -iE "fastapi|starlette|uvicorn|pydantic" > /tmp/vllm-pins.txt

# Install MiroFish Python dependencies (may conflict with vLLM)
COPY vendor/mirofish/backend/requirements.txt /app/mirofish-requirements.txt
RUN pip install --no-cache-dir -r /app/mirofish-requirements.txt 2>/dev/null || true
RUN pip install --no-cache-dir flask flask-cors requests zep-cloud 2>/dev/null || true

# Restore vLLM's pinned versions (vLLM is fragile about FastAPI/Starlette versions)
RUN pip install --no-cache-dir -r /tmp/vllm-pins.txt

# Ensure Flask is installed AFTER vLLM pin restore (pin restore can remove it)
RUN pip install --no-cache-dir --ignore-installed flask flask-cors requests zep-cloud && \
    python3 -c "import flask; print(f'Flask {flask.__version__} OK')"

# Copy MiroFish engine
COPY vendor/mirofish/backend/ /app/mirofish/backend/
COPY vendor/mirofish/package.json /app/mirofish/package.json

# Copy our job runner and worker API
COPY infra/docker/run_job.py /app/run_job.py
COPY infra/docker/worker_api.py /app/worker_api.py
COPY infra/docker/start.sh /app/start.sh
RUN chmod +x /app/run_job.py /app/start.sh

# Create directories for job data
RUN mkdir -p /tmp/results /tmp/seed

# Port 8000: vLLM OpenAI-compatible API
# Port 5000: worker HTTP job API
EXPOSE 5000 8000

# Override base image entrypoint (vllm/vllm-openai sets ENTRYPOINT to vLLM server)
# We need our own start script that launches both vLLM and the worker API
ENTRYPOINT []
CMD ["/bin/bash", "/app/start.sh"]
