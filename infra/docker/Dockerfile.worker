# GPU Worker Image for FishCloud (MiroShark engine)
# Based on vLLM's official image (has CUDA + vLLM + correct transformers pre-installed)
FROM vllm/vllm-openai:v0.8.5.post1 AS base

USER root

WORKDIR /app

# Save vLLM's pinned dependency versions
RUN pip freeze > /tmp/vllm-freeze.txt

# Install MiroShark dependencies (may conflict — we'll restore vLLM pins after)
COPY vendor/miroshark/backend/requirements.txt /app/miroshark-requirements.txt
RUN pip install --no-cache-dir --ignore-installed -r /app/miroshark-requirements.txt

# Install worker-specific deps
# Wonderwall deps: sentence-transformers, igraph, pandas, scikit-learn
# Don't use --ignore-installed for ML libs — reuse vLLM's torch/numpy (saves 2GB disk)
RUN pip install --no-cache-dir --ignore-installed flask flask-cors requests neo4j openai && \
    pip install --no-cache-dir sentence-transformers igraph pandas scikit-learn

# Restore vLLM's critical pins — MiroShark deps may upgrade numpy/starlette which breaks vLLM
# NOTE: transformers is intentionally excluded from restore — vLLM 0.8.5 ships 4.47.1
# which predates Qwen3 support (added in 4.51.0). We upgrade it below.
RUN grep -E "^(tokenizers|starlette|fastapi|uvicorn|numpy)==" /tmp/vllm-freeze.txt > /tmp/vllm-restore.txt && \
    pip install --no-cache-dir --force-reinstall -r /tmp/vllm-restore.txt

# Upgrade transformers for Qwen3 support (model_type "qwen3" requires >=4.51.0)
RUN pip install --no-cache-dir "transformers>=4.51.0,<4.55.0"

# Verify all imports + numpy<2 (vLLM ABI requirement) + Qwen3 config loads
RUN python3 -c "import vllm; print(f'vLLM {vllm.__version__}')" && \
    python3 -c "import numpy; print(f'numpy {numpy.__version__}')" && \
    python3 -c "import transformers; print(f'transformers {transformers.__version__}')" && \
    python3 -c "from transformers import AutoConfig; AutoConfig.from_pretrained('Qwen/Qwen3-14B', trust_remote_code=True); print('Qwen3-14B config OK')" && \
    python3 -c "import flask; print('Flask OK')" && \
    python3 -c "import neo4j; print('neo4j OK')" && \
    python3 -c "import openai; print('openai OK')"

# Copy MiroShark engine
COPY vendor/miroshark/backend/ /app/miroshark/backend/

# Copy our job runner modules and worker API
COPY infra/docker/constants.py /app/constants.py
COPY infra/docker/service_init.py /app/service_init.py
COPY infra/docker/graph_ops.py /app/graph_ops.py
COPY infra/docker/simulation.py /app/simulation.py
COPY infra/docker/results.py /app/results.py
COPY infra/docker/run_job.py /app/run_job.py
COPY infra/docker/worker_api.py /app/worker_api.py
COPY infra/docker/sim_data_extractor.py /app/sim_data_extractor.py
COPY infra/docker/start.sh /app/start.sh
RUN chmod +x /app/run_job.py /app/start.sh

RUN mkdir -p /tmp/results /tmp/seed

EXPOSE 5000 8000

ENTRYPOINT []
CMD ["/bin/bash", "/app/start.sh"]
