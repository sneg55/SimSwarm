# GPU Worker Image for FishCloud
# Uses Python 3.11 for camel-oasis compatibility
FROM nvidia/cuda:12.1.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install Python 3.11 + system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev \
    git curl wget build-essential \
    && rm -rf /var/lib/apt/lists/*

# Make python3.11 the default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3.11

WORKDIR /app

# Install MiroFish dependencies FIRST
COPY vendor/mirofish/backend/requirements.txt /app/mirofish-requirements.txt
RUN pip install --no-cache-dir --ignore-installed -r /app/mirofish-requirements.txt

# Install Flask + remaining deps
RUN pip install --no-cache-dir --ignore-installed flask flask-cors requests zep-cloud

# Install vLLM LAST so its pinned transformers/torch versions take precedence
RUN pip install --no-cache-dir "vllm>=0.6.0,<0.7.0"

# Copy MiroFish engine
COPY vendor/mirofish/backend/ /app/mirofish/backend/
COPY vendor/mirofish/package.json /app/mirofish/package.json

# Copy our job runner and worker API
COPY infra/docker/run_job.py /app/run_job.py
COPY infra/docker/worker_api.py /app/worker_api.py
COPY infra/docker/start.sh /app/start.sh
RUN chmod +x /app/run_job.py /app/start.sh

# Create directories for job data
RUN mkdir -p /tmp/results /tmp/seed

# Port 8000: vLLM OpenAI-compatible API
# Port 5000: worker HTTP job API
EXPOSE 5000 8000

CMD ["/bin/bash", "/app/start.sh"]
