# GPU Worker Image for FishCloud
# Based on vLLM's official image (has CUDA + vLLM pre-installed)
FROM vllm/vllm-openai:v0.6.6.post1 AS base

USER root

# Install additional system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install MiroFish Python dependencies first (cache layer)
COPY vendor/mirofish/backend/requirements.txt /app/mirofish-requirements.txt
RUN pip install --no-cache-dir --ignore-installed -r /app/mirofish-requirements.txt 2>/dev/null || \
    pip install --no-cache-dir --ignore-installed flask flask-cors requests

# Copy MiroFish engine
COPY vendor/mirofish/backend/ /app/mirofish/backend/
COPY vendor/mirofish/package.json /app/mirofish/package.json

# Copy our job runner and worker API
COPY infra/docker/run_job.py /app/run_job.py
COPY infra/docker/worker_api.py /app/worker_api.py
COPY infra/docker/start.sh /app/start.sh
RUN chmod +x /app/run_job.py /app/start.sh

# Ensure flask is available (MiroFish requirements may already include it)
RUN pip install --no-cache-dir flask || true

# Create directories for job data
RUN mkdir -p /tmp/results /tmp/seed

# Port 8000: vLLM OpenAI-compatible API
# Port 5000: worker HTTP job API
EXPOSE 5000 8000

# Entrypoint: start both vLLM and the worker API via start.sh
# MODEL_ID and VLLM_ARGS are set by the orchestrator
CMD ["/app/start.sh"]
